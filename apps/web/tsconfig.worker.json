{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "noEmit": false,
    "outDir": ".worker-dist",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["worker.ts", "lib/**/*.ts", "prisma/**/*.ts", "types/**/*.ts"]
}
